# SWSM init vars
####################################################################################
# Основные переменные окружения для сервера simple-windows-services-monitor (SWSM)

# Адрес подключения к базе данных PostgreSQL.
# Формат: postgres://<пользователь>:<пароль>@<хост>:<порт>/<имя_бд>?sslmode=disable
# Используется при локальной разработке — обращается к PostgreSQL, запущенному на localhost.
DATABASE_URI=postgres://swsm:userpassword@localhost:5432/swsm?sslmode=disable

# Для продакшена (например, при запуске в Docker), где база доступна по имени контейнера "db".
# Раскомментировать эту строку и закомментировать предыдущую перед сборкой продакшен-образа.
#DATABASE_URI=postgres://swsm:userpassword@db:5432/swsm?sslmode=disable

# Адрес и порт, на котором будет запущен HTTP-сервер приложения.
# Обычно для локальной разработки — 127.0.0.1:8080.
RUN_ADDRESS=127.0.0.1:8080

# Уровень логирования. Возможные значения: debug, info, warn, error.
# При debug выводится максимум диагностической информации.
LOG_LEVEL=debug

# Путь к файлу логов. Если указать ./logs/swsm.log — логи будут сохраняться в подкаталог logs.
LOG_OUTPUT=./logs/swsm.log

# Ключ для симметричного шифрования данных (например, при хранении паролей).
# Должен быть в формате base64 и одинаковым на всех экземплярах приложения.
AES_KEY=your-base64-key

# Флаг включения веб-интерфейса (true — фронтенд будет обслуживаться этим же сервером).
WEB_INTERFACE=true

# Базовый URL для API (используется во фронтенде).
# Для локальной разработки — полный путь (http://127.0.0.1:8080/api).
# Для продакшена, когда фронт и бэк на одном домене — относительный путь (/api).
API_BASE_URL=http://127.0.0.1:8080/api

# Backend postgres init vars (для образа postgres)
####################################################################################
# Переменные инициализации для контейнера PostgreSQL.
# Должны совпадать с логином, паролем и именем базы, указанными в DATABASE_URI.

# Имя пользователя PostgreSQL.
POSTGRES_USER=swsm

# Пароль пользователя PostgreSQL.
POSTGRES_PASSWORD=userpassword

# Имя базы данных PostgreSQL.
POSTGRES_DB=swsm

# Auth postgres init vars (для образа postgres)
####################################################################################
# Переменные инициализации для контейнера PostgreSQL.
# Должны совпадать с логином, паролем и именем базы, указанными в DATABASE_URI.

# Имя пользователя PostgreSQL.
KEYCLOAK_POSTGRES_USER=swsm_keycloak

# Пароль пользователя PostgreSQL.
KEYCLOAK_POSTGRES_PASSWORD=keycloak_db_userpassword

# Имя базы данных PostgreSQL.
KEYCLOAK_DB=swsm_keycloak

# Keycloak init vars (OpenID Connect)
####################################################################################
# Название realm в Keycloak
KEYCLOAK_REALM_NAME=swsm

# Базовый URL Keycloak сервера, включая realm.
# Формат: http(s)://<host>:<port>
# Пример: http://localhost:8081
# Также можно по имени контейнера, например: http://keycloak:8081
# или URL, где расположен ваш Keycloak, например: https://auth.example.com
KEYCLOAK_BASE_URL=http://localhost:8080

# НЕ ИСПОЛЬЗОВАТЬ В ПРОДАКШЕНЕ! Отключает проверку issuer.
# Требуется для локальной разработки в контейнерах.
KEYCLOAK_SKIP_ISSUER_CHECK=false

# Идентификатор клиента (client_id), зарегистрированного в Keycloak.
# Должен совпадать с именем клиента, указанным в консоли Keycloak.
KEYCLOAK_CLIENT_ID=swsm

# Ник администратора realm'а
KEYCLOAK_ADMIN_USERNAME=admin

# Пароль администратора realm'а
KEYCLOAK_ADMIN_PASSWORD=email_password